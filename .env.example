# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# eBay Developer Credentials
# Get these at developer.ebay.com → My Account → Application Keys
EBAY_APP_ID=YourName-YourApp-PRD-xxxxxxxxx-xxxxxxxx
EBAY_CERT_ID=PRD-xxxxxxxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx
EBAY_DEV_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# eBay User Token (OAuth — generated via Authorization Code flow)
# This is YOUR seller account token, not the app token
EBAY_USER_TOKEN=v^1.1#i^1#r^0#I^3#p^3#f^0#t^...

# Webhook config
# This must match the URL you register in eBay Developer portal
WEBHOOK_ENDPOINT=https://your-app.railway.app/webhook/ebay
EBAY_VERIFICATION_TOKEN=any-random-secret-string-you-choose
